{
  "name": "@forgespace/siza-gen",
  "version": "0.15.0",
  "description": "Siza AI generation engine — multi-framework code generation, component registry, and ML-powered quality scoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lite": {
      "import": "./dist/lite.js",
      "types": "./dist/lite.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsc --watch",
    "api:extract": "api-extractor run --local --config api-extractor.json && api-extractor run --local --config api-extractor-lite.json",
    "api:check": "api-extractor run --config api-extractor.json && api-extractor run --config api-extractor-lite.json",
    "api:docs": "api-documenter markdown --input-folder temp --output-folder docs/api",
    "clean": "rm -rf dist coverage .tsbuildinfo node_modules/.cache",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --onlyChanged",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint:check && npm run format:check && npm run typecheck && npm test",
    "validate:snippets": "npx tsx src/scripts/validate-all-snippets.ts",
    "validate:tokens": "npx tsx src/scripts/check-semantic-tokens.ts",
    "registry:stats": "npx tsx src/scripts/count-registry.ts",
    "export:training": "npx tsx src/scripts/export-training-data.ts",
    "seed:rules": "npx tsx src/scripts/seed-axe-core-rules.ts",
    "ingest:hf": "npx tsx src/scripts/ingest-huggingface.ts",
    "sidecar:start": "bash scripts/start-sidecar.sh",
    "sidecar:test": "cd python && source .venv/bin/activate && python -m pytest tests/ -v",
    "metrics:report": "curl -s http://localhost:8100/metrics/report | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
    "knip": "knip",
    "bench": "NODE_OPTIONS=--experimental-vm-modules npx tsx src/benchmark/run.ts",
    "bench:dry": "NODE_OPTIONS=--experimental-vm-modules npx tsx src/benchmark/run.ts --dry-run",
    "check:cycles": "madge --circular --extensions ts src/",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "better-sqlite3": "^12.6.2",
    "pino": "^10.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@microsoft/api-documenter": "^7.29.10",
    "@microsoft/api-extractor": "^7.58.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "knip": "^6.3.0",
    "madge": "^8.0.0",
    "prettier": "^3.0.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "code-generation",
    "component-registry",
    "mcp",
    "agent-tools",
    "react",
    "vue",
    "angular",
    "svelte",
    "typescript",
    "internal-developer-platform",
    "forgespace",
    "siza"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Forge-Space/siza-gen.git"
  },
  "bugs": {
    "url": "https://github.com/Forge-Space/siza-gen/issues"
  },
  "homepage": "https://github.com/Forge-Space/siza-gen#readme",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "axios": ">=0.0.0 <0.30.4 || >0.30.4 <1.14.1 || >=1.14.2",
    "madge": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/eslint-plugin": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/parser": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/typescript-estree": {
      "typescript": "$typescript"
    }
  }
}
